# ============================================================
# MULTI-SOURCE DATA INGESTION API KEYS
# Copy this file to .env and fill values locally.
# Do not commit .env.
# ============================================================
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_CONTACT_EMAIL=your-email@example.com
HUGGINGFACE_TOKEN=
GNEWS_API_KEY=
NEWSAPI_KEY=
GITHUB_TOKEN=
APIFY_API_TOKEN=
OPENAI_API_KEY=

# Research-Grade News APIs
GUARDIAN_API_KEY=
NYTIMES_API_KEY=

# Semantic web/search APIs
EXA_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=
FIRECRAWL_API_KEY=
APIFY_SCRAPER_TIMEOUT_SECS=300
APIFY_MAX_PAGES_PER_SCRAPE=10
APIFY_ENABLE_JAVASCRIPT=true

# Optional private-source credentials
GARTNER_USERNAME=
GARTNER_PASSWORD=
FORRESTER_USERNAME=
FORRESTER_PASSWORD=
BRIGHTEDGE_API_KEY=
SPRINKLR_API_KEY=
ADBEAT_API_KEY=

# Ingestion settings
RESEARCH_TOPICS=retrieval augmented generation,vector search,semantic search,embedding models,dense retrieval,RAG
MAX_PAPERS_PER_SOURCE=50
MAX_NEWS_ARTICLES_PER_SOURCE=100
MAX_GITHUB_REPOS=30
FETCH_INTERVAL_HOURS=6
RESEARCH_FETCH_HOUR=2
DEVELOPER_FETCH_HOUR=3
MIN_PUBLICATION_YEAR=2022
NEWS_LOOKBACK_DAYS=30

# Persistence
# Local default:
DATABASE_CONNECTION_STRING=sqlite:///./research_intel.db
# Production example:
# DATABASE_CONNECTION_STRING=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Email alerts
EMAIL_PROVIDER=resend
EMAIL_FROM=onboarding@resend.dev
DAILY_EMAIL_TO=
RESEND_API_KEY=

# App behavior
APP_ENV=local
LOG_LEVEL=INFO
SYSTEM_VERSION=0.1.0
DEFAULT_EMBEDDING_PROVIDER=local
DEFAULT_LLM_PROVIDER=optional_openai
ENABLE_BACKGROUND_SCHEDULER=false
ENABLE_DAILY_EMAIL=false
DAILY_EMAIL_HOUR=8
# Daily Intelligence v2
# Comma-separated topic scope (defaults cover AI, automation, sales, marketing and analytics)
DAILY_TOPICS=artificial intelligence,generative AI,agentic AI,RAG,enterprise AI,workflow automation,AI for sales,AI for marketing,business intelligence,developer tools
# JSON overrides per connector. Limits are examples only and should match current provider terms.
DAILY_SOURCE_BUDGETS_JSON={"arxiv":{"requests_per_minute":20,"maximum_items_per_run":100,"timeout_seconds":20,"retry_count":2},"semantic_scholar":{"requests_per_minute":60,"maximum_items_per_run":100},"serper":{"maximum_items_per_run":25,"priority":1},"exa":{"maximum_items_per_run":25,"priority":2}}
DAILY_MAX_CONTENT_CHARS=100000
DAILY_BACKGROUND_WORKERS=2
DAILY_DEFAULT_REVIEWER_ROLE=reviewer
